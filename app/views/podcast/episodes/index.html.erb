<h1 class="text-3xl font-bold text-maroon mb-8"><%= t(".title") %></h1>

<div class="bg-neutral-50 border border-neutral-200 rounded-lg p-4 mb-8"
     data-controller="clipboard">
  <h2 class="text-sm font-semibold text-neutral-700 mb-2"><%= t(".feed_url_title") %></h2>
  <div class="flex items-center gap-2">
    <input type="text"
           readonly
           value="<%= podcast_feed_url(format: :rss, token: @feed_token.token) %>"
           data-clipboard-target="source"
           class="flex-1 text-sm bg-white border border-neutral-300 rounded px-3 py-2 text-neutral-600 select-all">
    <button data-action="click->clipboard#copy"
            data-clipboard-target="button"
            class="px-3 py-2 bg-maroon text-white text-sm rounded hover:bg-maroon/90 transition-colors shrink-0">
      <%= t(".copy") %>
    </button>
  </div>
  <p class="text-xs text-neutral-500 mt-2"><%= t(".feed_url_hint") %></p>
</div>

<% if @episodes.any? %>
  <div class="space-y-6">
    <% @episodes.each do |episode| %>
      <article class="border-b border-neutral-200 pb-6">
        <h2 class="text-xl font-bold mb-1">
          <%= link_to episode.title, podcast_episode_path(episode), class: "text-maroon hover:underline" %>
        </h2>
        <div class="text-sm text-neutral-500 mb-3">
          <% if episode.published_at.present? %>
            <%= l(episode.published_at, format: :short) %>
          <% end %>
        </div>
        <% if episode.description.present? %>
          <p class="text-neutral-700"><%= truncate(episode.description, length: 300) %></p>
        <% end %>
      </article>
    <% end %>
  </div>

  <%= render "shared/pagy_nav", pagy: @pagy %>
<% else %>
  <p class="text-neutral-500"><%= t(".empty") %></p>
<% end %>
