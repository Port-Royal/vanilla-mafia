<nav aria-label="Breadcrumb" class="text-sm text-gray-500 mb-4">
  <% @game.competition.ancestors.each do |ancestor| %>
    <%= link_to ancestor.name, competition_path(slug: ancestor.slug), class: "text-maroon hover:underline" %> /
  <% end %>
  <%= link_to @game.competition.name, competition_path(slug: @game.competition.slug), class: "text-maroon hover:underline" %> /
  <span class="text-gray-700"><%= t("common.game") %> <%= @game.game_number %></span>
</nav>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-3xl font-bold text-maroon"><%= @game.full_name %></h1>
  <% if current_user&.can_manage_protocols? %>
    <%= link_to t("game_protocols.edit_link"), edit_judge_protocol_path(@game), class: "text-maroon hover:underline text-sm" %>
  <% end %>
</div>

<p class="text-lg text-gray-600 mb-2"><%= t(".result.#{@game.result}") %></p>
<% last_meta = @game.table_number.present? ? :table_number : (@game.judge.present? ? :judge : nil) %>
<% if @game.judge.present? %>
  <p class="text-sm text-gray-500 <%= last_meta == :judge ? 'mb-6' : 'mb-2' %>"><%= t(".judge", name: @game.judge) %></p>
<% end %>
<% if @game.table_number.present? %>
  <p class="text-sm text-gray-500 mb-6"><%= t(".table_number", number: @game.table_number) %></p>
<% end %>

<div class="scroll-wrapper">
  <table class="data-table">
    <thead>
      <tr>
        <th><%= t(".seat") %></th>
        <th><%= t(".player") %></th>
        <th><%= t(".role") %></th>
        <th><%= t(".base_score") %></th>
        <th><%= t(".additional_score") %></th>
        <th><%= t(".best_move") %></th>
        <th><%= t(".total") %></th>
      </tr>
    </thead>
    <tbody>
      <% @participations.each do |participation| %>
        <tr class="<%= 'bg-green-50' if participation.win %>">
          <td><%= participation.seat %></td>
          <td><%= link_to participation.player.name, player_path(participation.player), class: "text-maroon hover:underline" %></td>
          <td>
            <% if participation.role_code.present? %>
              <% role_label = participation.role&.name.presence || participation.role_code %>
              <%= image_tag "roles/#{participation.role_code}.png", alt: role_label, class: "inline-block h-6 w-6", title: role_label %>
            <% end %>
          </td>
          <td><%= participation.plus %></td>
          <td><%= participation.minus %></td>
          <td><%= participation.best_move %></td>
          <td><%= participation.total %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
