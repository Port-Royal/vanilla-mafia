<% max_length = FeatureToggle.value_for("news_max_article_length")&.to_i %>
<% is_truncated = max_length && max_length > 0 && article.truncated?(max_length) %>
<article class="border-b border-neutral-200 pb-6">
  <h2 class="text-xl font-bold mb-1">
    <%= link_to article.title, news_path(article), class: "hover:underline" %>
  </h2>
  <div class="text-sm text-neutral-500 mb-3">
    <% if article.published_at.present? %>
      <%= l(article.published_at, format: :full_date) %>
    <% end %>
    <% if article.author.claimed_player? %>
      · <%= article.author.player.name %>
    <% end %>
    <% if article.tags.any? %>
      <% article.tags.each do |tag| %>
        <span class="inline-block bg-neutral-100 text-neutral-600 text-xs px-2 py-0.5 rounded"><%= tag.name %></span>
      <% end %>
    <% end %>
  </div>
  <% if article.photos.attached? %>
    <div class="flex flex-wrap gap-2 mb-3">
      <% article.photos.each do |photo| %>
        <% if photo.variable? %>
          <%= image_tag photo.variant(resize_to_limit: [600, 400]), alt: article.title, class: "rounded max-w-full" %>
        <% end %>
      <% end %>
    </div>
  <% end %>
  <div class="prose max-w-none text-neutral-700">
    <% if is_truncated %>
      <%= article.truncated_content(max_length) %>
    <% else %>
      <%= article.content %>
    <% end %>
  </div>
  <% if is_truncated %>
    <div class="mt-2">
      <%= link_to t("news.index.read_more"), news_path(article),
            class: "text-sm text-blue-600 hover:underline" %>
    </div>
  <% end %>
  <% if user_signed_in? && current_user.can_manage_news? %>
    <div class="mt-2">
      <%= link_to t("news.index.edit"), edit_admin_news_path(article),
            class: "text-sm text-blue-600 hover:underline" %>
    </div>
  <% end %>
</article>
