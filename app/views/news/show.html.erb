<div class="mb-6">
  <%= link_to t("news.show.back"), news_index_path,
        class: "text-blue-600 hover:underline text-sm" %>
</div>

<article class="mb-6">
  <h1 class="text-2xl font-bold mb-1"><%= @news.title %></h1>
  <div class="text-sm text-neutral-500 mb-3">
    <% if @news.published_at.present? %>
      <%= l(@news.published_at, format: :full_date) %>
    <% end %>
    <% if @news.author.claimed_player? %>
      · <%= @news.author.player.name %>
    <% end %>
    <% if @news.tags.any? %>
      <% @news.tags.each do |tag| %>
        <span class="inline-block bg-neutral-100 text-neutral-600 text-xs px-2 py-0.5 rounded"><%= tag.name %></span>
      <% end %>
    <% end %>
  </div>
  <% if @news.photos.attached? %>
    <div class="flex flex-wrap gap-2 mb-3">
      <% @news.photos.each do |photo| %>
        <% if photo.variable? %>
          <%= image_tag photo.variant(resize_to_limit: [600, 400]), alt: @news.title, class: "rounded max-w-full" %>
        <% end %>
      <% end %>
    </div>
  <% end %>
  <div class="prose max-w-none text-neutral-700">
    <%= @news.content %>
  </div>
</article>

<% if user_signed_in? && current_user.can_manage_news? %>
  <div class="mt-2">
    <%= link_to t("news.index.edit"), edit_admin_news_path(@news),
          class: "text-sm text-blue-600 hover:underline" %>
  </div>
<% end %>
