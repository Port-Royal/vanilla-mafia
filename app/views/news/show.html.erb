<div class="mb-6">
  <%= link_to t(".back"), news_index_path,
        class: "text-maroon hover:underline text-sm" %>
</div>

<h1 class="text-3xl font-bold text-maroon mb-4"><%= @article.title %></h1>

<div class="text-sm text-neutral-500 mb-6">
  <% if @article.published_at.present? %>
    <%= l(@article.published_at, format: :short) %>
  <% end %>
  <% if @article.author.claimed_player? %>
    · <%= @article.author.player.name %>
  <% end %>
  <% if @article.game %>
    · <%= link_to t(".linked_game", game: @article.game.game_number),
          game_path(@article.game), class: "text-maroon hover:underline" %>
  <% end %>
  <% if @article.tags.any? %>
    · <% @article.tags.each do |tag| %>
      <span class="inline-block bg-neutral-100 text-neutral-600 text-xs px-2 py-0.5 rounded"><%= tag.name %></span>
    <% end %>
  <% end %>
</div>

<div class="prose max-w-none">
  <%= @article.content %>
</div>
