<h1 class="text-2xl font-bold mb-6"><%= t("admin_telegram.title") %></h1>

<div class="space-y-8">
  <%# Webhook Status %>
  <section class="bg-white border border-gray-200 rounded-lg shadow-sm p-6">
    <h2 class="text-lg font-semibold mb-4"><%= t("admin_telegram.webhook.title") %></h2>

    <% if @webhook_info.success %>
      <% if @webhook_info.url.present? %>
        <div class="space-y-2 text-sm">
          <p>
            <span class="inline-block px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800"><%= t("admin_telegram.webhook.active") %></span>
          </p>
          <p><span class="font-medium"><%= t("admin_telegram.webhook.url") %>:</span> <code class="bg-gray-100 px-1 rounded"><%= @webhook_info.url %></code></p>
          <p><span class="font-medium"><%= t("admin_telegram.webhook.pending_updates") %>:</span> <%= @webhook_info.pending_update_count %></p>
        </div>
      <% else %>
        <p class="text-sm">
          <span class="inline-block px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-800"><%= t("admin_telegram.webhook.inactive") %></span>
        </p>
      <% end %>
    <% else %>
      <p class="text-sm text-red-600"><%= t("admin_telegram.webhook.error", message: @webhook_info.description) %></p>
    <% end %>
  </section>

  <%# News Tag %>
  <section class="bg-white border border-gray-200 rounded-lg shadow-sm p-6">
    <h2 class="text-lg font-semibold mb-4"><%= t("admin_telegram.news_tag.title") %></h2>
    <p class="text-sm"><span class="font-medium"><%= t("admin_telegram.news_tag.current") %>:</span> <code class="bg-gray-100 px-1 rounded"><%= Telegram::MessageParser::NEWS_TAG_PATTERN %></code></p>
  </section>

  <%# Author Whitelist %>
  <section class="bg-white border border-gray-200 rounded-lg shadow-sm p-6">
    <h2 class="text-lg font-semibold mb-4"><%= t("admin_telegram.authors.title") %></h2>

    <% if @telegram_authors.any? %>
      <div class="mb-4">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 text-left">
              <th class="px-4 py-3 font-semibold"><%= t("admin_telegram.authors.user_id") %></th>
              <th class="px-4 py-3 font-semibold"><%= t("admin_telegram.authors.player") %></th>
              <th class="px-4 py-3 font-semibold"><%= t("admin_telegram.authors.linked_user") %></th>
              <th class="px-4 py-3 font-semibold"></th>
            </tr>
          </thead>
          <tbody class="divide-y">
            <% @telegram_authors.each do |author| %>
              <tr>
                <td class="px-4 py-3"><%= author.telegram_user_id %></td>
                <td class="px-4 py-3"><%= author.user&.player&.name %></td>
                <td class="px-4 py-3"><%= author.user&.email %></td>
                <td class="px-4 py-3 text-right">
                  <%= button_to t("admin_telegram.authors.remove"),
                        admin_telegram_author_path(author),
                        method: :delete,
                        class: "text-red-600 hover:underline text-sm",
                        data: { turbo_confirm: t("admin_telegram.authors.remove_confirm") } %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-gray-500 mb-4"><%= t("admin_telegram.authors.empty") %></p>
    <% end %>

    <h3 class="text-sm font-semibold mb-2"><%= t("admin_telegram.authors.add") %></h3>
    <%= form_with model: @telegram_author, url: admin_telegram_authors_path, class: "flex gap-3 items-end" do |f| %>
      <div>
        <%= f.label :telegram_user_id, t("admin_telegram.authors.user_id"), class: "block text-xs text-gray-600 mb-1" %>
        <%= f.number_field :telegram_user_id, class: "border border-gray-300 rounded px-3 py-1.5 text-sm", required: true %>
      </div>
      <div>
        <%= f.label :user_id, t("admin_telegram.authors.linked_user"), class: "block text-xs text-gray-600 mb-1" %>
        <%= f.select :user_id, options_for_select(@users.map { |u| ["#{u.player&.name} (#{u.email})", u.id] }, f.object.user_id), { include_blank: true }, class: "border border-gray-300 rounded px-3 py-1.5 text-sm" %>
      </div>
      <%= f.submit t("admin_telegram.authors.add_submit"), class: "bg-blue-500 hover:bg-blue-600 text-white font-medium py-1.5 px-4 rounded text-sm cursor-pointer" %>
    <% end %>
  </section>
</div>
