<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold"><%= t("admin_news.index.title") %></h1>
  <%= link_to t("admin_news.index.new"), new_admin_news_path,
        class: "bg-blue-500 hover:bg-blue-600 text-white font-medium py-2 px-4 rounded-md text-sm" %>
</div>

<% if @news.any? %>
  <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-gray-50 text-left">
          <th class="px-4 py-3 font-semibold"><%= News.human_attribute_name(:title) %></th>
          <th class="px-4 py-3 font-semibold"><%= t("admin_news.index.author") %></th>
          <th class="px-4 py-3 font-semibold"><%= News.human_attribute_name(:status) %></th>
          <th class="px-4 py-3 font-semibold"><%= News.human_attribute_name(:published_at) %></th>
          <th class="px-4 py-3 font-semibold"></th>
        </tr>
      </thead>
      <tbody class="divide-y">
        <% @news.each do |article| %>
          <tr>
            <td class="px-4 py-3">
              <%= link_to article.title, admin_news_path(article), class: "text-blue-600 hover:underline" %>
            </td>
            <td class="px-4 py-3"><%= article.author.email %></td>
            <td class="px-4 py-3">
              <span class="inline-block px-2 py-0.5 rounded text-xs font-medium <%= article.published? ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800' %>">
                <%= t("admin_news.status.#{article.status}") %>
              </span>
            </td>
            <td class="px-4 py-3"><%= article.published_at && l(article.published_at, format: :short) %></td>
            <td class="px-4 py-3 text-right">
              <%= link_to t("admin_news.index.edit"), edit_admin_news_path(article),
                    class: "text-blue-600 hover:underline text-sm" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-gray-500"><%= t("admin_news.index.empty") %></p>
<% end %>
