<section>
  <h2 class="text-2xl font-bold text-maroon mb-6"><%= t(".title") %></h2>

  <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    <% recently_finished.each do |competition| %>
      <div class="border border-gray-200 rounded-lg p-4">
        <h3 class="text-lg font-semibold mb-2">
          <%= link_to competition.name, competition_path(slug: competition.slug),
                class: "text-maroon hover:underline" %>
        </h3>

        <p class="text-sm text-neutral-500 mb-3">
          <%= t(".ended_on") %>: <%= format_date(competition.ended_on) %>
        </p>

        <% winner = winners[competition] %>
        <% if winner %>
          <p class="text-sm">
            <span class="font-medium"><%= t(".winner") %>:</span>
            <%= link_to winner.name, player_path(winner), class: "text-maroon hover:underline" %>
          </p>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
